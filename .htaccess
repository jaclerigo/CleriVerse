Options -Indexes

# ── Motor de reescrita (necessário para o router index.php) ─────────────────
RewriteEngine On
# Alterar /cleriverse/ para o caminho real do deploy (ex.: / na raiz)
RewriteBase /cleriverse/

# Redirecionar para HTTPS (descomentar em produção)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Ignorar ficheiros e directórios reais
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Enviar tudo para o index.php
RewriteRule ^ index.php [L,QSA]

# ── Cabeçalhos de segurança ──────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Proteger ficheiros sensíveis ─────────────────────────────────────────────
<FilesMatch "^(composer\.(json|lock)|\.env.*|.*\.sql)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ── Proteger directorias internas ────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteRule ^(config|src|database|pages|templates|vendor)/ - [F,L]
</IfModule>

# ── Compressão gzip ──────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>

# ── Cache de activos estáticos ───────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css             "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/svg+xml        "access plus 1 week"
</IfModule>
